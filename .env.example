# --- Required ---
# Public URL this deployment is reachable at (no trailing slash)
NEXT_PUBLIC_APP_URL=https://foyer.yourcompany.com
# Long random string; sessions and signed tokens depend on it
AUTH_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
# Must be a verified sender/domain in Resend
EMAIL_FROM=Foyer <docs@yourcompany.com>

# --- Database (docker-compose sets this automatically) ---
DATABASE_URL=postgresql://foyer:foyer@localhost:5433/foyer
POSTGRES_PASSWORD=foyer

# --- Storage (S3-compatible; docker-compose wires MinIO automatically) ---
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=foyer
S3_SECRET_ACCESS_KEY=foyer-secret
S3_BUCKET=foyer
S3_FORCE_PATH_STYLE=true
MINIO_PASSWORD=foyer-secret

# --- Optional: Cloudflare custom-domain auto-configuration ---
# API token with Zone -> DNS -> Edit on the zones you use for link domains.
# Teams can also paste a token per-domain in Settings -> Custom domains.
CLOUDFLARE_API_TOKEN=
